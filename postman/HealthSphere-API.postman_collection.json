      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Morning Strength Training\",\n  \"type\": \"Strength\",\n  \"duration\": 45,\n  \"caloriesBurned\": 320,\n  \"notes\": \"Felt strong today. Increased bench press by 5kg.\",\n  \"date\": \"2026-03-09T08:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions"]
            },
            "description": "Enregistre une nouvelle séance sportive (route protégée)."
